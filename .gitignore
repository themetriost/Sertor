.ruff_cache/
.ipynb_checkpoints/

# Packaging (sertor-core di produzione)
dist/
build/
*.egg-info/

# Vector store / indici locali (namespaced per corpus: .index, .index-sertor, .index-prototype, .index-wiki, ...)
**/chroma/
*.chroma
**/.index/
**/.index-*/
# Artefatti SQLite sotto <index_dir>: observability.sqlite, embed_cache.sqlite, memory.sqlite (031)
# Manifest + lockfile dell'indicizzazione incrementale (046, FEAT-009): rigenerabili.
**/index_manifest.sqlite
**/.index.lock
# Stato di salute RAG (076, E10-FEAT-011): rigenerabile a ogni SessionEnd, mai versionato.
**/.sertor/.rag-health.json
# Version-update check (077, E2-FEAT-013): stato + stamp installato, rigenerabili, mai versionati.
**/.sertor/.version-check.json
**/.sertor/.sertor-version
**/.sertor/.sertor-flow-version
# Lock volatile del runtime dogfood (088, E15-FEAT-008): tracks HEAD, rigenerato dal re-lock post-merge.
# Solo .sertor/pyproject.toml è versionato (spec stabile); il lock è locale per evitare churn/loop.
**/.sertor/uv.lock

# Log rigenerabili (re-index, ecc.)
**/*.log

# GraphRAG (Tappa 3C): venv isolato + artefatti rigenerabili (input staged da raw/)
prototype/03-graphrag/.venv-grag/
prototype/03-graphrag/*.log
prototype/03-graphrag/grag/input/
prototype/03-graphrag/grag/output/
prototype/03-graphrag/grag/output_*/
prototype/03-graphrag/grag/cache/
prototype/03-graphrag/grag/logs/
prototype/03-graphrag/grag/metrics/
prototype/03-graphrag/grag/update_output/
prototype/03-graphrag/entity_types_evidence.*

# OS / editor
.DS_Store
Thumbs.db
.vscode/

# Fonti esterne vendored in raw/ (riproducibili via sources/*.md): non versionare,
# ma tieni il nostro README della cartella. (corpus del prototipo, isolato in prototype/)
prototype/raw/*
!prototype/raw/README.md

# Machinery SpecKit materializzata dal percorso d'install (E10-FEAT-027) — RIGENERABILE come `.venv`:
# la produce `scripts/dev/materialize-speckit.ps1` (che lancia `specify init`, spec-kit pinnato). NON
# vendorata in git (eviterebbe drift di pin / re-vendoring, cfr. pivot launch-installer 045). Il dogfood
# la ottiene come un ospite, via lo step di setup. Restano TRACCIATI gli artefatti Sertor-authored:
# .specify/memory/constitution.md, .specify/templates/plan-template.md, .specify/feature.json.
.claude/skills/speckit-*/
.specify/scripts/
.specify/workflows/
.specify/integrations/
.specify/init-options.json
.specify/integration.json
.specify/templates/checklist-template.md
.specify/templates/constitution-template.md
.specify/templates/spec-template.md
.specify/templates/tasks-template.md
# Sertor RAG runtime (sertor install rag)
.sertor/.venv/
.sertor/.index*
.sertor/.env
.sertor/.rag-health.json
.sertor/.version-check.json
.sertor/.sertor-version
.sertor/.sertor-flow-version
.sertor/.last-hook-error

# Acta per-node config (host-specific, not shared)
.acta/
