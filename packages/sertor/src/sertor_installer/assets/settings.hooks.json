{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 15,
            "statusMessage": "Carico lo stato del wiki",
            "command": "uv run --no-project python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/wiki-session-start.py\" --assistant claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 95,
            "statusMessage": "Pavimento distill: gate sul merge",
            "command": "uv run --no-project python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/distill-floor.py\" --mode PreToolUse --assistant claude"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 20,
            "statusMessage": "Gate wiki: registra prima di chiudere",
            "command": "uv run --no-project python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/wiki-guard.py\" --mode Stop --assistant claude"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "uv run --no-project python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/wiki-pending-check.py\" --mode SessionEnd --assistant claude"
          }
        ]
      }
    ]
  }
}
