{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 15,
            "statusMessage": "Carico lo stato del wiki",
            "command": "uv run --no-project python .claude/hooks/wiki-session-start.py --assistant claude"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "statusMessage": "Verifico lo stato del wiki",
            "command": "uv run --no-project python .claude/hooks/wiki-pending-check.py --mode Stop --assistant claude"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "uv run --no-project python .claude/hooks/wiki-pending-check.py --mode SessionEnd --assistant claude"
          }
        ]
      }
    ]
  }
}
