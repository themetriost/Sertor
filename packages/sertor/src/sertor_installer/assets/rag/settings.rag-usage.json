{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "uv run --no-project python .claude/hooks/sertor-rag-usage-check.py --assistant claude"
          }
        ]
      }
    ]
  }
}
