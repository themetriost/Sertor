# Generated by `sertor install rag` (local provider). Do NOT commit.
# Embedding provider: glove (default, static NL vectors, ~822 MB download once per machine),
# hash (airgapped/CI, zero-download, lexical only), ollama (local model), azure (cloud).
SERTOR_EMBED_PROVIDER=glove
# Optional: path to a local glove.6B.300d.txt file (airgapped/offline; skips the download).
# SERTOR_GLOVE_PATH=
# Vector-store backend: local (default, Chroma) or azure (Azure AI Search).
# SERTOR_STORE_BACKEND=local
# Ollama host (only used when SERTOR_EMBED_PROVIDER=ollama; requires `ollama serve`).
OLLAMA_HOST=http://localhost:11434
SERTOR_CORPUS={corpus}
# Optional: cache embeddings by content-hash so re-indexing an unchanged corpus does not
# re-embed identical chunks (cuts the per-rebuild embedding cost). Default off.
# SERTOR_EMBED_CACHE=true
# Optional: keep the structured operational events in a local store (enables historical reports
# on cost, cache hit/miss, corpus health). Default off; only metrics, never query text.
# SERTOR_OBSERVABILITY=true
# Optional: ALSO export those events to an OpenTelemetry backend (Langfuse/Phoenix/Grafana). Needs the
# `[otel]` extra; endpoint/transport from the standard OTEL_EXPORTER_OTLP_* env vars. Default off.
# SERTOR_OBSERVABILITY_OTEL=true
# Optional, LOCAL demonstrability: also capture query text + result preview/snippet (secret-scrubbed)
# so the TUI "RAG" tab shows query/result/hit-miss. Needs SERTOR_OBSERVABILITY=true. Default off
# (privacy-by-default). For local use only — do NOT enable to track/audit users.
# SERTOR_OBSERVABILITY_CONTENT=true
# Incremental indexing (default ON): `sertor-rag index` refreshes only the changed files; pass
# --full to force a rebuild from scratch. Set to false to always rebuild fully.
# SERTOR_INDEX_INCREMENTAL=true
# Optional: run a full reconciliation rebuild every N incremental runs (0 = off, the default).
# SERTOR_INDEX_RECONCILE_EVERY=0
# Optional: hard cap (TOKENS) on a single chunk before embedding. Structural chunkers can emit a
# section/symbol larger than the embedding model's token budget → the provider rejects it. Oversized
# chunks are sub-split. Default 8191. Lower it for an embedder with a smaller context window.
# SERTOR_MAX_CHUNK_TOKENS=8191
# Optional: directory for the eval suite and baseline (versioned project data). Default "eval".
# SERTOR_EVAL_DIR=eval
# Optional: absolute tolerance for the non-regression gate (0.0 = zero tolerance). Default 0.0.
# SERTOR_EVAL_TOLERANCE=0.0
# Optional: absolute F1 tolerance for the graph-navigation non-regression gate (0.0 = zero tolerance).
# SERTOR_GRAPH_EVAL_TOLERANCE=0.0
# Optional: enable exact-set gate (case fails if got != expected). Default false.
# SERTOR_GRAPH_EVAL_EXACT=false
# Optional: top-k used to evaluate fusion coverage on "both" intent cases (default 5).
# SERTOR_EVAL_FUSION_K=5
# --- Conversation memory (optional, opt-in, privacy-by-default) -------------------------------
# Local episodic archive of past sessions, searchable for "did we discuss X?" recall, and a source
# for wiki distillation. OFF by default: nothing is captured or persisted until you set
# SERTOR_MEMORY=true. Content is stored locally (under .sertor/) and scrubbed of secrets; nothing
# leaves the machine. An end-of-session hook captures automatically when enabled.
# SERTOR_MEMORY=true
# Capture adapter (transcript source). Default: claude-code (reads ~/.claude/projects).
# SERTOR_MEMORY_ADAPTER=claude-code
# Optional: directory of the Claude Code projects (default ~/.claude/projects).
# SERTOR_MEMORY_CLAUDE_PROJECTS_DIR=
# Optional: retention hint in days (recorded only; enforcement is a future feature). Blank = keep.
# SERTOR_MEMORY_RETENTION_DAYS=
# Optional: extra secret-scrub regex patterns (comma-separated) applied to captured content.
# SERTOR_MEMORY_SCRUB_PATTERNS=
# Optional: max sessions returned by `sertor-rag memory list` (default 20).
# SERTOR_MEMORY_LIST_LIMIT=20
# Optional: max results from `sertor-rag memory search` (default 20).
# SERTOR_EPISODIC_LIMIT=20
# Optional: snippet length in tokens for episodic search results (default 12).
# SERTOR_EPISODIC_SNIPPET_TOKENS=12
# --- Semantic memory search (optional, a SECOND opt-in beyond SERTOR_MEMORY) -------------------
# Search the memory archive BY MEANING, not just by keyword. Embeds transcripts with the configured
# embeddings provider (SERTOR_EMBED_PROVIDER; the default is local, so content stays on the machine).
# A SEPARATE opt-in because embedding is an extra operation on the content. OFF by default. When on,
# `sertor-rag memory search --semantic` ranks past turns by meaning; new sessions are embedded
# incrementally at end of session, and `sertor-rag memory index-semantic` backfills existing ones.
# SERTOR_MEMORY_SEMANTIC=true
# Optional: max results from a semantic memory search (default 20).
# SERTOR_MEMORY_SEMANTIC_LIMIT=20
# Excludes the core defaults + `.sertor` (the runtime does not index itself).
SERTOR_EXCLUDE_PATTERNS=.venv,venv,env,node_modules,__pycache__,.pytest_cache,.ruff_cache,.mypy_cache,dist,build,target,bin,obj,out,.index,chroma,.idea,.vscode,*.key,*.pem,.env,.sertor
