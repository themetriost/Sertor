# Generato da `sertor install rag` (backend locale, Ollama). NON committare.
# Richiede Ollama in esecuzione (`ollama serve`) con un modello di embedding.
RAG_BACKEND=local
OLLAMA_HOST=http://localhost:11434
SERTOR_CORPUS={corpus}
# Esclude i default del core + `.sertor` (il runtime non si indicizza da solo).
SERTOR_EXCLUDE_PATTERNS=.venv,venv,env,node_modules,__pycache__,.pytest_cache,.ruff_cache,.mypy_cache,dist,build,target,bin,obj,out,.index,chroma,.idea,.vscode,*.key,*.pem,.env,.sertor
