# Generated by `sertor install rag` (local backend, Ollama). Do NOT commit.
# Requires Ollama running (`ollama serve`) with an embedding model.
RAG_BACKEND=local
OLLAMA_HOST=http://localhost:11434
SERTOR_CORPUS={corpus}
# Excludes the core defaults + `.sertor` (the runtime does not index itself).
SERTOR_EXCLUDE_PATTERNS=.venv,venv,env,node_modules,__pycache__,.pytest_cache,.ruff_cache,.mypy_cache,dist,build,target,bin,obj,out,.index,chroma,.idea,.vscode,*.key,*.pem,.env,.sertor
