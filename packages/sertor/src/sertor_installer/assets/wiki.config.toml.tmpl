# Host profile for the LLM Wiki.
#
# The SINGLE source of host-specifics: the `sertor-wiki-tools` deterministic core reads ONLY this
# file — no path/name/language/taxonomy is hard-coded in the code. To bring the capability to another
# project, all you need is a different file.
#
# Location: this file lives at `wiki/wiki.config.toml`. `root = "wiki"` stays relative to the HOST
# ROOT, not to this folder: tools pass `--root .` (or rely on the CLI auto-discovery). Clean host root.

profile = "code+doc"
language = "{language}"
root = "wiki"
index_file = "index.md"
log_file = "log.md"
log_dir = "log"  # log rotation: one file per day

source_dirs = {source_dirs}
exclude = [
    ".git", ".venv*", "venv", "__pycache__",
    ".ruff_cache", ".pytest_cache", ".mypy_cache",
    "node_modules", ".index*",
]
frontmatter_required = ["title", "type", "tags", "created", "updated"]
frontmatter_optional = ["sources", "status"]

[[taxonomy]]
name = "concepts"
dir = "concepts"
type = "concept"

[[taxonomy]]
name = "tech"
dir = "tech"
type = "tech"

[[taxonomy]]
name = "experiments"
dir = "experiments"
type = "experiment"

[[taxonomy]]
name = "sources"
dir = "sources"
type = "source"

[[taxonomy]]
name = "syntheses"
dir = "syntheses"
type = "synthesis"

[roles]
curator = "wiki-curator"

[rag]
enabled = false
corpus = "wiki"
