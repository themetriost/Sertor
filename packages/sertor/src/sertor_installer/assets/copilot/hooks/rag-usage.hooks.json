{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "timeout": 10,
            "command": "$d = if ($env:CLAUDE_PROJECT_DIR) { $env:CLAUDE_PROJECT_DIR } else { '.' }; & (Join-Path $d '.github/hooks/sertor-rag-usage-check.ps1')"
          }
        ]
      }
    ]
  }
}
