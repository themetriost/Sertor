# Template delle variabili d'ambiente. Copia in `.env` e compila (il `.env` NON va committato).

# Selettore backend: local | azure
RAG_BACKEND=local

# --- Ollama (locale) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
# Modello chat per l'Agentic RAG (Tappa 04): deve supportare il tool-calling
# (es. llama3.1, qwen3, mistral-nemo). Non serve alle Tappe 01–03.
OLLAMA_CHAT_MODEL=llama3.1

# --- Chunking del codice: treesitter (code-aware) | recursive (size-driven) ---
CODE_CHUNKER=treesitter

# --- Azure OpenAI / Azure AI Foundry (embeddings) ---
AZURE_OPENAI_ENDPOINT=https://<tuo-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBED_SMALL_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBED_LARGE_DEPLOYMENT=text-embedding-3-large

# --- Azure OpenAI / Azure AI Foundry (chat — usato da GraphRAG, Tappa 3C) ---
# Stessi endpoint + key degli embedding: qui cambia solo il deployment del modello chat.
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4-mini

# --- (Futuro) Azure AI Search ---
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=

# --- (Futuro) Azure Cosmos DB for NoSQL ---
COSMOS_ENDPOINT=
COSMOS_KEY=
