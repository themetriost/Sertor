{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "statusMessage": "Checking RAG freshness",
            "command": "uv run --no-project python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/rag-freshness-start.py\" --assistant claude"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "statusMessage": "Verifico la disponibilità di aggiornamenti Sertor",
            "command": "uv run --no-project python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/version-check-start.py\" --assistant claude"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 15,
            "statusMessage": "Carico lo stato del wiki",
            "command": "uv run --no-project python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/wiki-session-start.py\" --assistant claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "uv run --no-project python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/sertor-rag-usage-check.py\" --assistant claude"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 15,
            "command": "uv run --no-project python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/memory-capture.py\" --assistant claude"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 15,
            "command": "uv run --no-project python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/rag-freshness.py\" --assistant claude"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 15,
            "command": "uv run --no-project python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/version-check.py\" --assistant claude"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "uv run --no-project python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/wiki-pending-check.py\" --mode SessionEnd --assistant claude"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "statusMessage": "Verifico lo stato del wiki",
            "command": "uv run --no-project python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/wiki-pending-check.py\" --mode Stop --assistant claude"
          }
        ]
      }
    ]
  }
}
