# Esempio di configurazione per sertor-core. Copiare in `.env` (non versionato) e compilare.
# Tutte le scelte del nucleo passano da qui (config centralizzata, REQ-030). I segreti
# (chiavi API) NON vanno mai committati (REQ-032): `.env` è in `.gitignore`.

# --- backend & corpus ---
RAG_BACKEND=local            # local | azure
SERTOR_CORPUS=default        # namespace logico della collezione (per il server MCP su Sertor: `sertor`)

# --- embeddings: provider locale (Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBED_BATCH_SIZE=64

# --- embeddings: provider cloud (Azure OpenAI), solo se RAG_BACKEND=azure ---
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_EMBED_DEPLOYMENT=

# --- vector store ---
# locale: Chroma persistente; il path di default è gestito da Settings
# SERTOR_INDEX_DIR=.index
# cloud (Azure AI Search), solo se RAG_BACKEND=azure:
# AZURE_SEARCH_ENDPOINT=
# AZURE_SEARCH_API_KEY=

# --- chunking ---
CHUNK_SIZE=1600
CHUNK_OVERLAP=200

# --- retrieval ---
DEFAULT_K=5
