# Esempio di configurazione per sertor-core. Copiare in `.env` (non versionato) e compilare.
# Tutte le scelte del nucleo passano da qui (config centralizzata, REQ-030). I segreti
# (chiavi API) NON vanno mai committati (REQ-032): `.env` è in `.gitignore`.

# --- provider di embeddings & store ---
# Provider di EMBEDDINGS (RAG_BACKEND e' stato RIMOSSO — non piu' onorato):
#   glove  = vettori statici GloVe 6B 300d (DEFAULT, semantica NL locale; download ~822 MB una-tantum
#            per-macchina, licenza PDDL/pubblico dominio)
#   hash   = pavimento lessicale char-n-gram (airgapped/CI, zero-download, NL limitata)
#   ollama = modello locale (richiede `ollama serve`)
#   azure  = cloud (credenziali Azure OpenAI richieste)
SERTOR_EMBED_PROVIDER=glove
# Override del file GloVe locale (airgapped/offline; salta il download):
# SERTOR_GLOVE_PATH=/path/to/glove.6B.300d.txt
SERTOR_CORPUS=default        # namespace logico della collezione (per il server MCP su Sertor: `sertor`)
# Backend del VECTOR STORE, disaccoppiato dal provider di embeddings (default `local`).
# Es. `azure` (Azure AI Search) combinabile con qualsiasi provider di embeddings.
# SERTOR_STORE_BACKEND=local   # local | azure

# --- embeddings: provider locale (Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBED_BATCH_SIZE=64

# --- embeddings: provider cloud (Azure OpenAI), solo se SERTOR_EMBED_PROVIDER=azure ---
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_EMBED_DEPLOYMENT=

# --- vector store ---
# locale: Chroma persistente; il path di default è gestito da Settings
# SERTOR_INDEX_DIR=.index
# cloud (Azure AI Search), solo se SERTOR_STORE_BACKEND=azure:
# AZURE_SEARCH_ENDPOINT=
# AZURE_SEARCH_API_KEY=

# --- chunking ---
CHUNK_SIZE=1600
CHUNK_OVERLAP=200

# --- retrieval ---
DEFAULT_K=5
